      "architecture": { "value": "x64", "strategy": "set" },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "LAYTON_TARGET_OS": "windows",
        "LAYTON_TARGET_ARCH": "x64"
      }
    },
    {
